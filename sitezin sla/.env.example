# Supabase
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Fluxo oficial
# - Frontend (Vite) + Supabase (Auth/DB)
# - Deploy direto no Cloudflare
# - Docker nao e utilizado

# Backend Node local (opcional, apenas para localhost)
# Se nao for usar o backend local, voce pode deixar estas variaveis sem valor.
DATABASE_URL=postgresql://SEU_USUARIO:SEU_SEGREDO@localhost:5432/taylorswift
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ENABLE_UNSCOPED_ITEMS_API=false

# JWT
JWT_SECRET=seu_jwt_secret_super_seguro_aqui

# Node env
NODE_ENV=development

# Feature Flags
VITE_ENABLE_WORKSPACES=false
